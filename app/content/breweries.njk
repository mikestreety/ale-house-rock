---
layout: default.njk
intro: A list of breweries whose beer has been reviewed
---

<h1>Breweries</h1>

<table>
	<tr>
		<th>Brewery</th>
		<th>No. of Beers</th>
		<th>Average score</th>
		<th>Median score</th>
	</tr>
	{% for brewery in breweries %}
	<tr>
		<td><a href="{{ brewery.slug }}">{{ brewery.title }}</a></td>
		<td>{{ brewery.beers.length }}</td>
		<td>{{ brewery.meta.mean }}</td>
		<td>{{ brewery.meta.median }}</td>
	</tr>
	{% endfor %}
</table>
