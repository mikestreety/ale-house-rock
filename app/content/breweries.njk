---
layout: default.njk
seoTitle: Breweries
intro: A list of breweries whose beer has been reviewed
---

<h1>Breweries <small>({{ collections.sortedBreweries | length }})</small></h1>

<table>
	<tr>
		<th>Brewery</th>
		<th>No. of Beers</th>
		<th>Average score</th>
		<th>Median score</th>
	</tr>
	{% for brewery in collections.sortedBreweries %}
	<tr>
		<td><a href="{{ brewery.url }}">{{ brewery.data.title }}</a></td>
		<td>{{ brewery.data.beers.length }}</td>
		<td><span class="rating">{{ brewery.data.stats.mean }}</span></td>
		<td><span class="rating">{{ brewery.data.stats.median }}</span></td>
	</tr>
	{% endfor %}
</table>

<script src="/assets/js/table-sort.js"></script>
