---
permalink: api/beers.json
sitemapIgnore: true
---
[
	{% for beer in collections.beer %}
	{
		"number": "{{ beer.data.number }}",
		"title": "{{ beer.data.title }}",
		"image": "{{ beer.data.imagePath }}",
		"thumbnail": "{{ beer.data.thumbnailPath }}",
		"brewery": "{{ beer.data.brewedBy }}",
		"rating": "{{ beer.data.rating }}",
		"filename": "{{ beer.page.inputPath }}",
		"canonical": "{{ beer.data.canonical }}",
		{% if beer.data.abv %}"abv": "{{ beer.data.abv }}",{% endif %}
		{% if beer.data.style %}"style": "{{ beer.data.style }}",{% endif %}
		{% if beer.data.serving %}"serving": "{{ beer.data.serving }}",{% endif %}
		"date": "{{ beer.data.date | dateISOShort }}",
		"breweries": [
			{% for brewery in beer.data.breweries %}
			{
				"title": "{{ brewery.data.title }}",
				"slug": "{{ brewery.url }}"
			}{% if not loop.last %},{% endif %}
			{% endfor %}
		],
		"slug": "{{ beer.url }}"
	}{% if not loop.last %},{% endif %}
	{% endfor %}
]
