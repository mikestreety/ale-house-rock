---
permalink: _redirects
sitemapIgnore: true
---

# Shortcut for each beer number
{%- for item in collections.beer %}
{{ item.url | replace( r/\/$/ , "" ) }}-{{ item.data.number }}/	{{ item.url }}
{{ '' }}
{%- if item.data.number > 598 and item.data.number < 813 -%}
{{ item.url | replace( r/\/$/ , "" ) }}-{{ item.data.number + 1 }}/	{{ item.url }}
{%- endif -%}

	{%- if item.data.aliases -%}
		{%- for alias in item.data.aliases %}
/beer/{{ alias }}/	/{{ item.data.permalink }}
		{%- endfor %}
	{%- endif -%}
{%- endfor %}

# Brewery Aliases
{%- for brewery in collections.breweryAliases %}
	{%- for alias in brewery.data.aliases %}
/brewery/{{ alias }}/	/{{ brewery.data.permalink }}
	{%- endfor %}
{%- endfor %}
