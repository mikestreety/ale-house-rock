---
layout: default.njk
---
<main class="singlebeer">
	<div class="wrapper">
		<a href="{{ imagePath }}">
			<img src="{{ thumbnailPath }}" width="200" height="200" loading="lazy" alt="{{ brewedBy }} - {{ title }}">
		</a>
		<div class="content">
			<div>
				{% for brewery in breweries %}
				<a href="{{ brewery.url }}" class="brewery">{{ brewery.data.title }}</a>{{ ", " if not loop.last else "" }}
				{% endfor %}
			</div>
			<div class="title">{{ title }}</div>
			<div class="rating">{{ rating }}</div>
			<div class="meta">
				<div>{{ date | dateLong }}</div>
				<div class="number">{{ number }}</div>
			</div>
		</div>
	</div>
	<p>{{ review | safe }}</p>

	{% if style %}
	<p><strong>Style:</strong>
		<a href="/style/{{ style | slugify }}/">{{ style }}</a>
	</p>
	{% endif %}

	{% if abv %}
	<p><strong>ABV:</strong>
		{{ abv }}
	</p>
	{% endif %}

	{% if purchased %}
	<p><strong>Purchased:</strong>
		{% for shop in purchased_from %}<a href="{{ shop.url }}" class="shop">{{ shop.data.title }}</a>{% endfor %}
	</p>
	{% endif %}

	{% for tag in tags %}{% include 'tag.njk' %}{% endfor %}

	<p><small><a href="{{ canonical }}">View original post</a></small></p>

	{% if breweries and breweries.length > 0 %}
	<h2>{{ "Brewery" if breweries.length === 1 else "Breweries" }}</h2>
	<ul class="list listSmall">
		{% for brewery in breweries %}
		<li>
			<a href="{{ brewery.url }}" title="{{ brewery.data.title }}">
				{% if brewery.data.imagePath %}
				<img src="{{ brewery.data.imagePath }}" width="150" height="150" loading="lazy" alt="{{ brewery.data.title }}">
				{% endif %}
			</a>
			<div class="content">
				<a href="{{ brewery.url }}" class="title">{{ brewery.data.title }}</a>
				{% if brewery.data.location %}
				<div class="location">{{ brewery.data.location }}</div>
				{% endif %}
			</div>
		</li>
		{% endfor %}
	</ul>
	{% endif %}
</main>
<nav>
	<h2>View other beers</h2>
	<ul class="list listSmall">
		{% if relatedBeersByStyle %}
			{% set beer = relatedBeersByStyle %}
			{% include 'beer.njk' %}
		{% endif %}
		{% if relatedBeersByShop %}
			{% set beer = relatedBeersByShop %}
			{% include 'beer.njk' %}
		{% endif %}
		{% if relatedBeersByBrewery %}
			{% set beer = relatedBeersByBrewery %}
			{% include 'beer.njk' %}
		{% endif %}
	</ul>
</nav>
