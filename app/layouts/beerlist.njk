---
layout: default.njk
---
<aside class="filters">
	<a href="/ordered/rating" class="sort {{ "active" if page.url == '/ordered/rating/' else ''}}">Sort by Rating</a>
</aside>
<main id="beers">
	<ul class="list">
		{% for beer in pagination.items %}
			<li>
				<a href="{{ beer.slug }}" title="">
					<img src="{{ meta.img }}{{ beer.id }}/small.webp" width="150" height="150" loading="lazy" alt="{{ beer.brewery }} - {{ beer.title }}">
				</a>
				<div class="content">
					<a href="{{ beer.brewery_slug }}" class="brewery">{{ beer.brewery }}</a>
					<a href="{{ beer.slug }}" class="title">{{ beer.title }}</a>
					<div class="rating">{{ beer.rating }}</div>
					<div class="meta">
						<div class="number">{{ beer.number }} - {{ beer.date | readableDate }}</div>
					</div>
				</div>
			</li>
		{% endfor %}
	</ul>

	<nav class="pagination">
		{% if pagination.href.next %}
		<a class="button button-small historical" rel="prev" href="{{ pagination.href.next }}">
			&lsaquo; Older
		</a>
		{% endif %}
		{% if pagination.href.previous %}
		<a class="button button-small" rel="next" href="{{ pagination.href.previous }}">
			Newer &rsaquo;
		</a>
		{% endif %}
	</nav>

</main>
